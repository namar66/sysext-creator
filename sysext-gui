def tr(key, *args):
    text = I18N[CURRENT_LANG].get(key, key)
    if args:
        return text.format(*args)
    return text

# ======================================================================
# 1. THREAD: REPOSITORY SEARCH (DNF Search)
# ======================================================================
class SearchWorker(QThread):
    result_found = pyqtSignal(str, str)
    finished = pyqtSignal()

    def __init__(self, keyword):
        super().__init__()
        self.keyword = keyword

    def run(self):
        try:
            process = subprocess.run(
                ["sysext-creator", "search", self.keyword],
                capture_output=True, text=True
            )
            for line in process.stdout.splitlines():
                line = line.strip()
                if not line or line.startswith("=>") or line.startswith("PACKAGE") or line.startswith("BALÍČEK") or line.startswith("----"):
                    continue
                parts = line.split(maxsplit=1)
                if parts:
                    name = parts[0]
                    desc = parts[1] if len(parts) > 1 else tr("no_summary")
                    self.result_found.emit(name, desc)
        except Exception as e:
            print(f"[ERROR Search] {e}")
        self.finished.emit()

# ======================================================================
# 2. THREAD: ACTIONS (INSTALL, RM, UPDATE) + AUTO-CONFIRM
# ======================================================================
class ActionWorker(QThread):
    finished = pyqtSignal(bool, str, str, str)

    def __init__(self, action, target=None):
        super().__init__()
        self.action = action
        self.target = target

    def run(self):
        cmd = ["sysext-creator", self.action]
        if self.target:
            cmd.append(self.target)

        if self.action == "rm":
            cmd.append("yes")

        try:
            process = subprocess.run(cmd, capture_output=True, text=True)
            if process.returncode == 0:
                if self.target:
                    ext_pattern = f"/var/lib/extensions/{self.target}-fc*.raw"
                    old_pattern = f"/var/lib/extensions/{self.target}.raw"

                    if self.action == "install":
                        for _ in range(20):
                            if glob.glob(ext_pattern) or glob.glob(old_pattern): break
                            time.sleep(0.5)
                    elif self.action == "rm":
                        for _ in range(20):
                            if not glob.glob(ext_pattern) and not glob.glob(old_pattern): break
                            time.sleep(0.5)
                elif self.action == "update":
                    time.sleep(2.5)

                self.finished.emit(True, process.stdout, self.action, self.target or "")
            else:
                self.finished.emit(False, process.stderr or process.stdout, self.action, self.target or "")
        except Exception as e:
            self.finished.emit(False, str(e), self.action, self.target or "")

# ======================================================================
# 3. THREAD: VERSION LOADING
# ======================================================================
class VersionWorker(QThread):
    version_found = pyqtSignal(str, str)
    finished = pyqtSignal()

    def run(self):
        try:
            process = subprocess.run(["sysext-creator", "list"], capture_output=True, text=True)
            for line in process.stdout.splitlines():
                line = line.strip()
                if "📦" in line and ("(Version: " in line or "(Verze: " in line):
                    separator = " (Version: " if " (Version: " in line else " (Verze: "
                    parts = line.split("📦 ")[1].split(separator)
                    if len(parts) == 2:
                        name = parts[0].strip()
                        version = parts[1].replace(")", "").strip()
                        self.version_found.emit(name, version)
        except Exception as e:
            print(f"[ERROR Version] {e}")
        self.finished.emit()

# ======================================================================
# 4. THREAD & DIALOG: SYSEXT DOCTOR (DIAGNOSTICS)
# ======================================================================
class DoctorWorker(QThread):
    finished = pyqtSignal(int, str)

    def run(self):
        try:
            # Diagnostika běží nativně jako uživatel
            # a komunikuje s root démonem přes staging složku.
            process = subprocess.run(
                ["sysext-creator", "doctor"],
                capture_output=True,
                text=True
            )
            output = (process.stdout + "\n" + process.stderr).strip()
            self.finished.emit(process.returncode, output)
        except FileNotFoundError:
            self.finished.emit(-1, "FileNotFound")
        except Exception as e:
            self.finished.emit(-2, str(e))

class DoctorDialog(QDialog):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setWindowTitle(tr("doctor_title"))
        self.resize(750, 500)

        layout = QVBoxLayout(self)

        self.lbl_status = QLabel(tr("doctor_init"))
        self.lbl_status.setStyleSheet("font-weight: bold; font-size: 14px;")
        layout.addWidget(self.lbl_status)

        self.text_output = QPlainTextEdit()
        self.text_output.setReadOnly(True)
        font = QFont("Monospace")
        font.setStyleHint(QFont.StyleHint.Monospace)
        font.setPointSize(10)
        self.text_output.setFont(font)
        layout.addWidget(self.text_output)

        self.btn_close = QPushButton(tr("btn_close"))
        self.btn_close.clicked.connect(self.accept)
        self.btn_close.setEnabled(False)
        layout.addWidget(self.btn_close)

    def run_diagnostics(self):
        self.worker = DoctorWorker()
        self.worker.finished.connect(self.on_finished)
        self.worker.start()

    def on_finished(self, returncode, output):
        self.btn_close.setEnabled(True)

        if returncode == 0:
            self.lbl_status.setText(tr("doctor_success"))
            self.lbl_status.setStyleSheet("font-weight: bold; font-size: 14px; color: green;")
            self.text_output.setPlainText(output)
        elif returncode in [126, 127]:
            self.lbl_status.setText(tr("doctor_cancel"))
            self.lbl_status.setStyleSheet("font-weight: bold; font-size: 14px; color: red;")
            self.text_output.setPlainText(tr("doctor_cancel_msg"))
        elif returncode == -1:
            self.lbl_status.setText(tr("doctor_critical"))
            self.lbl_status.setStyleSheet("font-weight: bold; font-size: 14px; color: red;")
            self.text_output.setPlainText(tr("doctor_critical_msg"))
        else:
            self.lbl_status.setText(tr("doctor_warning"))
            self.lbl_status.setStyleSheet("font-weight: bold; font-size: 14px; color: orange;")
            self.text_output.setPlainText(output)

# ======================================================================
# MAIN MANAGER WINDOW
# ======================================================================
class SysextManager(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle(tr("app_title"))
        self.resize(850, 600)
        self.active_workers = []

        self.setWindowIcon(QIcon.fromTheme("sysext-creator-icon"))

        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        main_layout = QVBoxLayout(central_widget)

        header = QLabel(tr("header_title"))
        header.setStyleSheet("font-size: 18px; font-weight: bold; margin-bottom: 10px;")
        main_layout.addWidget(header)

        self.tabs = QTabWidget()
        main_layout.addWidget(self.tabs)

        self.setup_installed_tab()
        self.setup_explore_tab()
        self.setup_logs_tab() # NOVÁ ZÁLOŽKA
        self.load_installed_packages()

    def setup_installed_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        self.installed_table = QTableWidget(0, 4)
        self.installed_table.setHorizontalHeaderLabels([tr("col_pkg"), tr("col_ver"), tr("col_status"), tr("col_action")])
        self.installed_table.horizontalHeader().setSectionResizeMode(0, QHeaderView.ResizeMode.Stretch)
        self.installed_table.setColumnWidth(1, 150)
        layout.addWidget(self.installed_table)

        btn_layout = QHBoxLayout()
        self.version_btn = QPushButton(tr("btn_load_ver"))
        self.version_btn.clicked.connect(self.load_versions)

        self.doctor_btn = QPushButton(tr("btn_doctor"))
        self.doctor_btn.clicked.connect(self.open_doctor_dialog)

        self.refresh_btn = QPushButton(tr("btn_update_all"))
        self.refresh_btn.clicked.connect(self.update_all)

        btn_layout.addWidget(self.version_btn)
        btn_layout.addWidget(self.doctor_btn)
        btn_layout.addStretch()
        btn_layout.addWidget(self.refresh_btn)

        layout.addLayout(btn_layout)
        self.tabs.addTab(tab, tr("tab_installed"))

    def setup_explore_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        search_layout = QHBoxLayout()
        self.search_input = QLineEdit()
        self.search_input.setPlaceholderText(tr("search_placeholder"))
        self.search_input.returnPressed.connect(self.start_search)

        self.search_btn = QPushButton(tr("btn_search"))
        self.search_btn.clicked.connect(self.start_search)

        search_layout.addWidget(self.search_input)
        search_layout.addWidget(self.search_btn)
        layout.addLayout(search_layout)

        self.search_table = QTableWidget(0, 3)
        self.search_table.setHorizontalHeaderLabels([tr("col_avail_pkg"), tr("col_summary"), tr("col_action")])
        self.search_table.horizontalHeader().setSectionResizeMode(1, QHeaderView.ResizeMode.Stretch)
        layout.addWidget(self.search_table)
        self.tabs.addTab(tab, tr("tab_explore"))

    # ==========================================
    # NOVÁ METODA PRO ZÁLOŽKU LOGŮ
    # ==========================================
    def setup_logs_tab(self):
        tab = QWidget()
        layout = QVBoxLayout(tab)

        ctrl_layout = QHBoxLayout()
        self.refresh_logs_btn = QPushButton(tr("btn_refresh_logs"))
        self.refresh_logs_btn.clicked.connect(self.load_logs)
        
        self.autoscroll_cb = QCheckBox(tr("cb_autoscroll"))
        self.autoscroll_cb.setChecked(True)

        ctrl_layout.addWidget(self.refresh_logs_btn)
        ctrl_layout.addWidget(self.autoscroll_cb)
        ctrl_layout.addStretch()
        layout.addLayout(ctrl_layout)

        self.logs_text = QPlainTextEdit()
        self.logs_text.setReadOnly(True)
        font = QFont("Monospace")
        font.setStyleHint(QFont.StyleHint.Monospace)
        font.setPointSize(10)
        self.logs_text.setFont(font)
        layout.addWidget(self.logs_text)

        self.tabs.addTab(tab, tr("tab_logs"))

        # Časovač pro živé aktualizace (tail -f)
        self.log_path = "/var/log/sysext-creator.log"
        self.last_log_size = 0
        self.log_timer = QTimer(self)
        self.log_timer.timeout.connect(self.check_log_updates)
        self.log_timer.start(1500) # Kontrola každé 1.5 sekundy
        
        self.load_logs()

    def load_logs(self):
        if not os.path.exists(self.log_path) or os.path.getsize(self.log_path) == 0:
            self.logs_text.setPlainText(tr("msg_no_logs"))
            self.last_log_size = 0
            return

        try:
            with open(self.log_path, 'r', encoding='utf-8') as f:
                content = f.read()
                self.logs_text.setPlainText(content)
                self.last_log_size = os.path.getsize(self.log_path)

                # Automatické rolování dolů, pokud je zaškrtnuto
                if self.autoscroll_cb.isChecked():
                    scrollbar = self.logs_text.verticalScrollBar()
                    scrollbar.setValue(scrollbar.maximum())
        except Exception as e:
            self.logs_text.setPlainText(f"Error reading logs: {e}")

    def check_log_updates(self):
        # Aktualizujeme logy POUZE tehdy, pokud je uživatel na této záložce
        # (index 2), aby to zbytečně nežralo výkon na pozadí.
        if self.tabs.currentIndex() == 2:
            if os.path.exists(self.log_path):
                current_size = os.path.getsize(self.log_path)
                if current_size != self.last_log_size:
                    self.load_logs()

    # ==========================================

    def send_notification(self, title, message):
        try:
            subprocess.Popen(["notify-send", title, message, "--icon", "sysext-creator-icon", "--app-name", "Sysext-Creator"])
        except Exception as e:
            print(f"[DEBUG] Notification failed: {e}")

    def load_installed_packages(self):
        self.installed_table.setRowCount(0)
        ext_dir = "/var/lib/extensions"
        if not os.path.exists(ext_dir): return

        packages = set()
        for f in os.listdir(ext_dir):
            if f.endswith('.raw'):
                clean_name = re.sub(r'-fc\d+$', '', f[:-4])
                packages.add(clean_name)

        for pkg in sorted(packages):
            row = self.installed_table.rowCount()
            self.installed_table.insertRow(row)
            self.installed_table.setItem(row, 0, QTableWidgetItem(pkg))
            self.installed_table.setItem(row, 1, QTableWidgetItem("---"))

            status_item = QTableWidgetItem(tr("status_installed"))
            status_item.setForeground(Qt.GlobalColor.green)
            self.installed_table.setItem(row, 2, status_item)

            rm_btn = QPushButton(tr("btn_remove"))
            rm_btn.clicked.connect(lambda checked, p=pkg, b=rm_btn: self.remove_package(p, b))
            self.installed_table.setCellWidget(row, 3, rm_btn)

    def load_versions(self):
        self.version_btn.setText(tr("state_loading"))
        self.version_btn.setEnabled(False)
        self.v_worker = VersionWorker()
        self.v_worker.version_found.connect(self.update_version_in_table)
        self.v_worker.finished.connect(lambda: self.version_btn.setText(tr("btn_load_ver")) or self.version_btn.setEnabled(True))
        self.v_worker.start()

    def update_version_in_table(self, name, version):
        for row in range(self.installed_table.rowCount()):
            item = self.installed_table.item(row, 0)
            if item and item.text() == name:
                v_item = QTableWidgetItem(version)
                v_item.setForeground(Qt.GlobalColor.darkBlue if version not in ["unknown", "neznámá"] else Qt.GlobalColor.red)
                self.installed_table.setItem(row, 1, v_item)
                break

    def install_package(self, pkg_name, btn):
        btn.setText(tr("state_installing"))
        btn.setEnabled(False)
        self.run_action_worker("install", pkg_name)

    def remove_package(self, pkg_name, btn):
        if QMessageBox.question(self, tr("dialog_confirm_title"), tr("dialog_confirm_rm", pkg_name),
                               QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No) == QMessageBox.StandardButton.Yes:
            btn.setText(tr("state_removing"))
            btn.setEnabled(False)
            self.run_action_worker("rm", pkg_name)

    def update_all(self):
        self.refresh_btn.setText(tr("state_updating"))
        self.refresh_btn.setEnabled(False)
        self.run_action_worker("update", None)

    def run_action_worker(self, action, target):
        worker = ActionWorker(action, target)
        worker.finished.connect(self.on_action_finished)
        self.active_workers.append(worker)
        worker.start()

    def on_action_finished(self, success, message, action, target):
        self.load_installed_packages()
        self.refresh_btn.setText(tr("btn_update_all"))
        self.refresh_btn.setEnabled(True)

        act_names = {"install": tr("op_install"), "rm": tr("op_rm"), "update": tr("op_update")}
        title = act_names.get(action, "Operation")

        if success:
            msg = tr("msg_pkg_success", target) if target else tr("msg_all_success")
            self.send_notification(tr("op_completed", title), msg)
            if action == "install": self.mark_as_installed_in_search(target)
        else:
            QMessageBox.critical(self, tr("dialog_error_title"), tr("dialog_error_msg", title.lower(), message))

        self.active_workers = [w for w in self.active_workers if w.isRunning()]

    def mark_as_installed_in_search(self, name):
        for row in range(self.search_table.rowCount()):
            item = self.search_table.item(row, 0)
            if item and item.text() == name:
                info = QTableWidgetItem(tr("status_installed"))
                info.setForeground(Qt.GlobalColor.green)
                self.search_table.setItem(row, 2, info)

    def start_search(self):
        keyword = self.search_input.text().strip()
        if not keyword: return
        self.search_btn.setEnabled(False)
        self.search_table.setRowCount(0)
        self.worker = SearchWorker(keyword)
        self.worker.result_found.connect(self.add_search_result)
        self.worker.finished.connect(lambda: self.search_btn.setEnabled(True))
        self.worker.start()

    def add_search_result(self, name, desc):
        row = self.search_table.rowCount()
        self.search_table.insertRow(row)
        self.search_table.setItem(row, 0, QTableWidgetItem(name))
        self.search_table.setItem(row, 1, QTableWidgetItem(desc))

        if glob.glob(f"/var/lib/extensions/{name}-fc*.raw") or glob.glob(f"/var/lib/extensions/{name}.raw"):
            info = QTableWidgetItem(tr("status_installed"))
            info.setForeground(Qt.GlobalColor.green)
            self.search_table.setItem(row, 2, info)
        else:
            btn = QPushButton(tr("btn_install"))
            btn.clicked.connect(lambda ch, p=name, b=btn: self.install_package(p, b))
            self.search_table.setCellWidget(row, 2, btn)

    def open_doctor_dialog(self):
        dialog = DoctorDialog(self)
        dialog.show()
        dialog.run_diagnostics()

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setDesktopFileName("sysext-creator")
    window = SysextManager()
    window.show()
    sys.exit(app.exec())
