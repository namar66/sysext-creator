_sysext_creator_completions() {
    local cur prev cmds
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # OPRAVA 1: Přidán 'doctor' (a volitelně 'audit') do hlavní nabídky
    cmds="install update check-update rm list search doctor audit"

    if [[ ${COMP_CWORD} -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "${cmds}" -- "${cur}") )
        return 0
    fi

    case "${prev}" in
        install|search)
            compopt -o default
            COMPREPLY=()
            ;;
        rm|update) # OPRAVA 2: 'update' teď také nabízí nainstalované obrazy
            local installed=$(ls /var/lib/extensions/*.raw 2>/dev/null | xargs -n1 basename -s .raw | sed 's/-fc[0-9]\+$//' | sort -u 2>/dev/null || true)
            COMPREPLY=( $(compgen -W "${installed}" -- "${cur}") )
            ;;
        doctor|audit|list|check-update)
            # Tyto příkazy už neberou žádné další argumenty
            COMPREPLY=()
            ;;
        *)
            ;;
    esac
}
complete -F _sysext_creator_completions sysext-creator
